0" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3444163718" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>1. 미국, 우크라이나 안보 지원 재개… 우크라이나는 휴전 제안 수용 의사</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2003226283" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>요약: 미국이 우크라이나와의 회담 뒤 군사 지원 및 정보 공유를 재개하기로 했고, 우크라이나는 30일 휴전 제안을 받아들일 준비가 됐다고 밝혔습니다. 향후 공은 러시아로 넘어갔다는 평가가 핵심입니다.</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="446703455" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>출처: Reuters | 날짜: 2025-03-11</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3899240115" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>원문 링크: https://www.reuters.com/world/us-ukraine-meet-saudi-arabia-after-disastrous-white-house-talks-2025-03-11</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="4161759017" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t /></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3054834013" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>2. 이스라엘, 이란 정권 붕괴 불확실성 인정</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3709490729" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>요약: 이스라엘 내부에서는 대규모 공습에도 불구하고 이란 정권 붕괴를 장담할 수 없다는 평가가 나왔습니다. 전쟁의 단기 종결 가능성도 낮게 보고 있어 중동 긴장이 이어질 가능성이 큽니다.</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2380319618" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>출처: Reuters | 날짜: 2026-03-11</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2758114719" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>원문 링크: https://www.investing.com/news/world-news/israel-sees-no-certainty-irans-government-will-fall-despite-war-4554266</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="1791920208" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t /></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="4035197851" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>3. 국제유가, 비축유 대규모 방출 논의와 공급 우려 사이에서 급등락</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="1004792597" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>요약: 국제에너지기구(IEA)의 사상 최대 규모 비축유 방출 검토 소식이 유가를 누르는 한편, 중동 전쟁에 따른 실제 공급 차질 우려가 가격을 다시 떠받치고 있습니다. 에너지 시장 변동성이 매우 커진 상태입니다.</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="322629043" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>출처: Reuters | 날짜: 2026-03-10/11</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="185856908" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>원문 링크: https://reut.rs/4bdSiff</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3193260626" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t /></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3450495418" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>4. 폭스바겐, 관세 부담과 중국 경쟁 심화로 이익 반토막</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="1280729835" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>요약: 폭스바겐은 미국 관세 부담과 중국 시장 점유율 하락 여파로 영업이익이 크게 감소했다고 밝혔습니다. 전통 자동차 업체들이 지정학과 전기차 경쟁 압박을 동시에 받고 있음을 보여주는 사례입니다.</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3822343187" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>출처: Reuters | 날짜: 2026-03-10</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2178843150" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>원문 링크: https://reut.rs/46SdGFB</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="488779574" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t /></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2107674895" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>5. 미국, AI 칩 수출 새 규제 검토… 해외 기업의 미국 투자 요구 가능성</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2378318001" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>요약: 미국이 AI 칩 수출 승인 조건으로 외국 기업이나 국가에 미국 내 데이터센터 투자 또는 안보 보장을 요구하는 새 규제를 검토 중인 것으로 전해졌습니다. 반도체·AI 공급망 경쟁이 더 강한 산업정책 단계로 가고 있다는 신호입니다.</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="3180899213" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>출처: Reuters | 날짜: 2026-03-05</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="414582034" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t>원문 링크: https://www.reuters.com/world/us-mulls-new-rules-ai-chip-exports-including-requiring-investments-by-foreign-2026-03-05/</hp:t></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p><hp:p id="2368910647" paraPrIDRef="0" styleIDRef="0" pageBreak="0" columnBreak="0" merged="0"><hp:run charPrIDRef="0"><hp:t /></hp:run><hp:linesegarray><hp:lineseg textpos="0" vertpos="0" vertsize="1200" textheight="1200" baseline="1020" spacing="720" horzpos="0" horzsize="42520" flags="393216" /></hp:linesegarray></hp:p></hs:sec>